<Window x:Class="cv7.EditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:cv7" d:DataContext="{d:DesignInstance Type=local:Customer}"
        mc:Ignorable="d"
        Title="EditDialog" Height="450" Width="800">

    <Window.Resources>
        <local:UpperConverter x:Key="myConv" />
        <local:VisibilityConverter x:Key="visConv" />
    </Window.Resources>
    
    <StackPanel>
        <DockPanel>
            <Label Content="Jmeno" />
            <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource myConv}}" />
        </DockPanel>

        <DockPanel Visibility="{Binding FirstName, Converter={StaticResource visConv}}">
            <Label Content="Prijmeni" />
            <TextBox Text="{Binding LastName}" />
        </DockPanel>
    </StackPanel>
</Window>
